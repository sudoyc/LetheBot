{
  "name": "lethebot",
  "version": "0.1.0",
  "description": "A persistent, local-first chatbot with thick memory layer and Pi-based reasoning core",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "release:preflight": "tsx src/scripts/release-preflight.ts",
    "release:check": "pnpm typecheck && pnpm lint && pnpm build && pnpm release:preflight && pnpm test:run && git diff --check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "smoke": "tsx scripts/smoke-test.ts",
    "cli": "tsx src/cli/main.ts",
    "deploy:configure": "tsx src/scripts/deploy-napcat.ts --mode=configure",
    "deploy:docker": "tsx src/scripts/deploy-napcat.ts --mode=docker",
    "deploy:systemd": "tsx src/scripts/deploy-napcat.ts --mode=systemd",
    "deploy:pm2": "tsx src/scripts/deploy-napcat.ts --mode=pm2",
    "verify:onebot": "tsx src/scripts/verify-napcat.ts",
    "verify:napcat": "tsx src/scripts/verify-napcat.ts",
    "acceptance:evidence-template": "tsx src/scripts/local-acceptance-evidence.ts",
    "acceptance:db-summary": "tsx src/scripts/local-acceptance-evidence.ts --summarize-db",
    "acceptance:validate-evidence": "tsx src/scripts/local-acceptance-evidence.ts --validate",
    "ops:backup": "tsx src/scripts/ops-maintenance.ts backup",
    "ops:restore": "tsx src/scripts/ops-maintenance.ts restore",
    "ops:retention": "tsx src/scripts/ops-maintenance.ts retention",
    "ops:metrics": "tsx src/scripts/ops-maintenance.ts metrics",
    "ops:doctor": "tsx src/scripts/ops-maintenance.ts doctor",
    "ops:rehearse-maintenance": "tsx src/scripts/ops-maintenance.ts rehearse-maintenance",
    "ops:rehearse-rollback": "tsx src/scripts/ops-maintenance.ts rehearse-rollback",
    "ops:activate-release": "tsx src/scripts/application-release.ts activate",
    "ops:confirm-release": "tsx src/scripts/application-release.ts confirm",
    "ops:recover-release": "tsx src/scripts/application-release.ts recover",
    "ops:rehearse-application-rollback": "tsx src/scripts/application-release.ts rehearse",
    "ops:rehearse-cross-version": "tsx src/scripts/application-release.ts rehearse-cross-version",
    "ops:worker-soak": "tsx src/scripts/ops-maintenance.ts worker-soak"
  },
  "keywords": [
    "chatbot",
    "qq",
    "onebot",
    "memory",
    "ai",
    "pi"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "lethebotSchema": {
    "contractVersion": 1,
    "targetVersion": 6,
    "minReadableVersion": 1,
    "maxReadableVersion": 6,
    "adoptsLegacyUnversioned": true
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.2",
    "@earendil-works/pi-ai": "^0.80.2",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "minimatch": "^10.2.5",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "ulid": "^2.3.0",
    "ulidx": "^2.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
