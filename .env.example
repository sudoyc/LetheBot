# LetheBot Configuration Example
# Copy to .env and fill in values. Do not commit .env.

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Test mode uses the in-process mock Pi runtime and disables external Pi calls.
LETHEBOT_TEST=false

# Database path
LETHEBOT_DB_PATH=./data/lethebot.db

# Raw event retention (days, 0 = forever)
LETHEBOT_RAW_EVENT_RETENTION_DAYS=90
# Retention used by pnpm ops:retention (days, 0 = forever)
LETHEBOT_CHAT_MESSAGE_RETENTION_DAYS=90
LETHEBOT_AUDIT_LOG_RETENTION_DAYS=90
LETHEBOT_DISABLED_DELETED_MEMORY_RETENTION_DAYS=365

# Pi runtime configuration used by src/index.ts
# Set PI_PROVIDER=mock for local dry runs, or configure a real provider/model.
PI_PROVIDER=mock
PI_MODEL=mock
# PI_BASE_URL=https://api.deepseek.com/v1
# PI_API_KEY=

# SnowLuma / OneBot transport.
# ws is the default production path; http keeps reverse HTTP compatibility.
ONEBOT_TRANSPORT=ws
ONEBOT_WS_URL=ws://localhost:3001/
ONEBOT_HTTP_URL=http://localhost:3000
# If set, LetheBot requires incoming reverse HTTP events to use:
# Authorization: Bearer <ONEBOT_TOKEN>
# or SnowLuma X-Signature: sha1=<hmac-sha1(rawBody, ONEBOT_TOKEN)>.
# The same token is used for outgoing OneBot HTTP/WS API calls.
ONEBOT_TOKEN=

# Bot QQ id used for exact CQ @ mention detection in group chats.
LETHEBOT_BOT_QQ_ID=

# LetheBot HTTP Server Configuration
LETHEBOT_PORT=6700
LETHEBOT_HOST=0.0.0.0
LETHEBOT_HEALTH_PATH=/healthz
LETHEBOT_EVENT_PATH=/onebot/event
