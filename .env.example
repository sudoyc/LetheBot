# LetheBot Configuration Example
# Copy to .env and fill in values

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Test mode (disables external API calls)
LETHEBOT_TEST=false

# Optional: Pi API credentials (Phase G+)
# LETHEBOT_PI_API_KEY=
# LETHEBOT_PI_PROVIDER=

# Optional: NapCat connection (Phase E+)
# LETHEBOT_NAPCAT_WS_URL=ws://localhost:3001
# LETHEBOT_BOT_QQ_ID=

# Database path
LETHEBOT_DB_PATH=./data/lethebot.db

# Raw event retention (days, 0 = forever)
LETHEBOT_RAW_EVENT_RETENTION_DAYS=90
