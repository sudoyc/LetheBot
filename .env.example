# LetheBot Configuration Example
# Copy to .env and fill in values. Do not commit .env.
# LetheBot does not auto-load this file. Pass it explicitly with
# `node --env-file=.env ...` or configure it in the process manager.

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Test mode uses the in-process mock Pi runtime and rule-driven evaluator stub.
# It disables external Pi and evaluator calls.
LETHEBOT_TEST=false

# Background summaries read retained conversation text and may send it to the
# configured Pi provider. Keep disabled unless that exposure is authorized.
LETHEBOT_BACKGROUND_SUMMARY_ENABLED=false

# Database path
LETHEBOT_DB_PATH=./data/lethebot.db

# Numeric runtime identity used by Docker Compose bind mounts. Pre-create the
# host data directory with this owner; the image defaults to node (1000:1000).
LETHEBOT_UID=1000
LETHEBOT_GID=1000

# Raw event retention (days, 0 = forever)
LETHEBOT_RAW_EVENT_RETENTION_DAYS=90
# Retention used by pnpm ops:retention (days, 0 = forever)
LETHEBOT_CHAT_MESSAGE_RETENTION_DAYS=90
LETHEBOT_AUDIT_LOG_RETENTION_DAYS=90
LETHEBOT_DISABLED_DELETED_MEMORY_RETENTION_DAYS=365
LETHEBOT_EVENT_PROCESSING_FAILURE_RETENTION_DAYS=90

# Pi runtime configuration used by src/index.ts
# Set PI_PROVIDER=mock for local dry runs, or configure a real provider/model.
PI_PROVIDER=mock
PI_MODEL=mock
PI_TURN_TIMEOUT_MS=120000
# PI_BASE_URL=https://api.deepseek.com/v1
# PI_API_KEY=

# Structured evaluator configuration.
# With EVALUATOR_PROVIDER and EVALUATOR_MODEL unset, social/tool evaluation
# inherits the complete PI provider/model/base/key identity above. If either
# identity field is set, set both and provide a separate evaluator key.
EVALUATOR_TIMEOUT_MS=30000
EVALUATOR_MAX_RETRIES=1
EVALUATOR_TEMPERATURE=0
EVALUATOR_PROMPT_VERSION=lethebot-governance-v1
# EVALUATOR_PROVIDER=openai
# EVALUATOR_MODEL=deepseek-chat
# EVALUATOR_BASE_URL=https://api.deepseek.com/v1
# EVALUATOR_API_KEY=

# SnowLuma / OneBot transport.
# ws is the default production path; http keeps reverse HTTP compatibility.
ONEBOT_TRANSPORT=ws
ONEBOT_WS_URL=ws://localhost:3001/
ONEBOT_HTTP_URL=http://localhost:3000
# If set, LetheBot requires incoming reverse HTTP events to use:
# Authorization: Bearer <ONEBOT_TOKEN>
# or SnowLuma X-Signature: sha1=<hmac-sha1(rawBody, ONEBOT_TOKEN)>.
# The same token is used for outgoing OneBot HTTP/WS API calls.
ONEBOT_TOKEN=

# Bot QQ id used for exact CQ @ mention detection in group chats.
LETHEBOT_BOT_QQ_ID=

# Optional bot-owner QQ id used only for governance authority. This is distinct
# from the bot account id above and must be a raw 5-12 digit QQ id.
# LETHEBOT_BOT_OWNER_QQ_ID=123456789

# LetheBot HTTP Server Configuration
LETHEBOT_PORT=6700
LETHEBOT_HOST=0.0.0.0
LETHEBOT_HEALTH_PATH=/healthz
LETHEBOT_READINESS_PATH=/readyz
LETHEBOT_METRICS_PATH=/metrics
LETHEBOT_EVENT_PATH=/onebot/event
